{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vayu-webapp",
  "workers_dev": true,
  "compatibility_date": "2026-06-24",
  "main": "worker.ts",
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      "binding": "VAYU_KV",
      "id": "82eb79f074484b3ba9dc68ba10d0c48b"
    }
  ],
  "r2_buckets": [
    {
      "binding": "VAYU_R2",
      "bucket_name": "vayu-r2-bucket"
    }
  ]
}
